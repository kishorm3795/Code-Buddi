# ==========================================
# Frontend (.env for the Frontend directory)
# ==========================================
VITE_BACKEND_API_URL=http://localhost:5003
VITE_GEMINI_API_URL=http://localhost:5001
VITE_TEMP_SHARE_URL=http://localhost:5002
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ==========================================
# Backend - Login (.env for Backend/Login)
# ==========================================
PORT=5003
GOOGLE_CLIENT_ID=your_google_client_id_here
MONGO_URI=mongodb://127.0.0.1:27017/codebuddi
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
OTP_EMAIL_SERVICE=gmail
OTP_EMAIL_USER=your_email@gmail.com
OTP_EMAIL_PASS=your_email_app_password
JWT_SECRET=your_jwt_secret_here

# ==========================================
# Backend - Genai (.env for Backend/Genai)
# ==========================================
# GEMINI_API_KEY=your_gemini_api_key_here (If needed by google-generativeai, though code uses GEMINI_MODEL)
GEMINI_MODEL=gemini-2.5-pro
GEMINI_MODEL_1=gemini-1.5-flash
JWT_SECRET=your_jwt_secret_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ==========================================
# Backend - TempFile (.env for Backend/TempFile)
# ==========================================
TEMP_FILE_URL=http://localhost:5002
JWT_SECRET=your_jwt_secret_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
